# Database (NeonDB)
DATABASE_URL="postgresql://username:password@host.neon.tech/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Resend (Email)
RESEND_API_KEY="re_xxxx"
FROM_EMAIL="noreply@gdsmarriagelinks.com"
SUPPORT_EMAIL="support@gdsmarriagelinks.com"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# UploadThing (Image Upload)
UPLOADTHING_TOKEN="your-uploadthing-token"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GDS Marriage Links"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxx"

# Admin Access (comma-separated emails)
ADMIN_EMAILS="admin@gdsmarriagelinks.com"

# Socket.io (optional — real-time messaging; leave empty for serverless deployments)
NEXT_PUBLIC_SOCKET_URL=""
