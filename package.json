    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.9",
