    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pluralize": "^8.0.0",
    "radix-ui": "^1.4.3",
    "razorpay": "^2.9.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.4",
